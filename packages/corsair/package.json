    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.6",
    "@types/react-test-renderer": "^19.1.0",
    "better-sqlite3": "^12.0.0",
    "dotenv": "^17.2.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "js-yaml": "^4.1.0",
    "node-fetch-native": "^1.6.7",
    "postgres": "^3.4.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-test-renderer": "^19.2.7",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.1",
    "tsx": "^4.20.6",
    "typescript": "^5.3.3"
  },
