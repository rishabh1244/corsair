{
  "name": "corsair",
  "version": "0.1.99",
  "description": "",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "dev-source": "./index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "dev-source": "./core.ts",
      "types": "./dist/core.d.ts",
      "default": "./dist/core.js"
    },
    "./db": {
      "dev-source": "./db.ts",
      "types": "./dist/db.d.ts",
      "default": "./dist/db.js"
    },
    "./orm": {
      "dev-source": "./orm.ts",
      "types": "./dist/orm.d.ts",
      "default": "./dist/orm.js"
    },
    "./setup": {
      "dev-source": "./setup.ts",
      "types": "./dist/setup.d.ts",
      "default": "./dist/setup.js"
    },
    "./http": {
      "dev-source": "./http.ts",
      "types": "./dist/http.d.ts",
      "default": "./dist/http.js"
    },
    "./oauth": {
      "dev-source": "./oauth.ts",
      "types": "./dist/oauth.d.ts",
      "default": "./dist/oauth.js"
    },
    "./tunnel": {
      "dev-source": "./tunnel.ts",
      "types": "./dist/tunnel.d.ts",
      "default": "./dist/tunnel.js"
    },
    "./hub": {
      "dev-source": "./hub.ts",
      "types": "./dist/hub.d.ts",
      "default": "./dist/hub.js"
    },
    "./tests": {
      "dev-source": "./tests.ts",
      "types": "./dist/tests.d.ts",
      "default": "./dist/tests.js"
    },
    "./client/react": {
      "dev-source": "./client/react/index.ts",
      "types": "./dist/client/react/index.d.ts",
      "default": "./dist/client/react/index.js"
    }
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:api": "jest --testPathPattern=api\\.test\\.ts",
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "ind": "tsx index.ts"
  },
  "dependencies": {
    "kysely": "^0.28.5",
